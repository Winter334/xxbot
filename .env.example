# Discord BOT 令牌
DISCORD_BOT_TOKEN=请替换为你的 Discord BOT Token

# Discord 应用 ID，用于命令同步等场景
DISCORD_APPLICATION_ID=123456789012345678

# 数据库连接地址
# 本地开发默认建议使用 SQLite
# PostgreSQL 示例：postgresql+psycopg://postgres:postgres@127.0.0.1:5432/xxbot_next
DATABASE_URL=sqlite+pysqlite:///./data/app.db

# Discord 命令同步目标 guild。
# 留空时不做开发 guild 同步。
DISCORD_GUILD_ID=

# 日志级别
LOG_LEVEL=INFO

# 批处理 AI 命名提供方配置
# 三项都填写时，才会启用 HTTP AI 命名提供方
AI_NAMING_API_KEY=
AI_NAMING_API_URL=
AI_NAMING_MODEL=
